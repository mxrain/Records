# GitHub 配置
NEXT_PUBLIC_GITHUB_OWNER=your_github_username
NEXT_PUBLIC_GITHUB_REPO=your_repo_name
NEXT_PUBLIC_GITHUB_RESOURCES_REPO=your_resources_repo_name
GITHUB_TOKEN=your_github_token

# 安全配置
ENCRYPTION_KEY=your_encryption_key
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
VERIFY_PASSWORD=your_verify_password
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Turnstile 验证码配置
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# 验证系统配置
AUTH_ENABLED=true
AUTH_PASSWORD_ENV_KEY=VERIFY_PASSWORD
AUTH_TURNSTILE_ENABLED=false
AUTH_TURNSTILE_SITE_KEY=your_site_key
AUTH_TURNSTILE_SECRET_KEY=your_secret_key

# Neon PostgreSQL 配置 (免费 0.5GB)
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Upstash Redis 配置 (免费 256MB)
REDIS_URL=redis://default:password@your-upstash-redis.upstash.io:6379

# Cloudflare R2 对象存储配置 (免费 10GB)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=records

# Google Analytics (可选)
NEXT_PUBLIC_GA_ID=your_ga_id
